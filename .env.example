# ============================================================
# MediCare Pro — vitrine + CMS
# Copier vers .env.local puis remplir. Tout ce qui est Supabase/
# IA/GSC/SMTP est OPTIONNEL en Phase 1 : sans ces variables, le
# site sert le contenu embarqué (fallback) et l'admin est inactif.
# ============================================================

# URL publique du site vitrine
NEXT_PUBLIC_SITE_URL=https://medicarepro.fr

# URL du logiciel MediCare (app SaaS) vers lequel la vitrine redirige (inscription, connexion).
NEXT_PUBLIC_APP_URL=https://app.medicarepro.fr

# --- Supabase (CMS) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Réservé aux scripts (migrations/seed) — jamais lu par l'app :
SUPABASE_DB_URL=

# --- Secrets applicatifs ---
# Protège les routes /api/jobs/* (cron) — 32+ caractères aléatoires
CRON_SECRET=
# Protège l'activation de la preview brouillon (/api/draft)
DRAFT_PREVIEW_SECRET=

# --- IA (génération articles & pages villes) ---
ANTHROPIC_API_KEY=
# ID de modèle versionné (vérifier la liste via GET /v1/models)
ANTHROPIC_MODEL=

# --- Google Search Console (suivi du référencement) ---
GSC_SITE_URL=sc-domain:medicarepro.fr
# Clé JSON du service account, encodée en base64
GSC_SERVICE_ACCOUNT_KEY_B64=

# --- Email transactionnel (formulaire de contact) ---
# Sans SMTP_HOST/USER/PASS, le formulaire renvoie une erreur d'envoi.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Adresse expéditrice (From) — le serveur SMTP doit être autorisé à l'émettre.
SMTP_FROM=noreply@medicarepro.fr
# Destinataire des demandes du formulaire de contact.
CONTACT_TO=contact@medicarepro.fr

# ============================================================
# BILLING — tunnel d'inscription payante (/inscription).
# Le tunnel refuse de s'ouvrir (503) tant que ces variables
# manquent : on n'encaisse jamais sans pouvoir chiffrer les
# secrets ni provisionner le compte app.
# ============================================================

# --- Monetico (CIC) — contrat 7807486, société MEDICARE PRO ---
# Le contrat porte CINQ TPE virtuels, un par mode de paiement.
# Un TPE = un mode, et UNE CLÉ PROPRE : la clé d'un TPE ne vaut
# rien pour un autre.
#   NB8179I  Paiement immédiat
#   NB8179D  Paiement différé
#   NB8179P  Paiement partiel
#   NB8179R  Paiement RÉCURRENT  ← celui des abonnements
#   NB8179F  Paiement fractionné
# Les abonnements MediCare Pro (mensuel comme 12 mois) sont
# reconduits automatiquement par la banque : ils DOIVENT passer
# par le TPE récurrent, sinon rien n'est jamais représenté.
MONETICO_TPE=NB8179R
# Code société attribué par le CIC (variante _hf = français seul).
MONETICO_SOCIETE=medicarepr
# test → p.monetico-services.com/test/paiement.cgi (code-retour payetest)
# Le NUMÉRO de TPE est le même en test et en production : seule la
# clé change. Basculer = changer MONETICO_MODE, rien d'autre.
MONETICO_MODE=test
# Clés de sécurité du TPE ci-dessus : 40 caractères, une par
# environnement, à télécharger dans le tableau de bord Monetico
# (Paramétrage > Obtention de la clé de sécurité).
MONETICO_KEY_TEST=
MONETICO_KEY_PROD=
# Repli hérité, sans suffixe — ne l'utiliser que le temps d'une
# transition, la clé du mode courant l'emporte toujours.
MONETICO_KEY=

# --- API de provisioning de l'app (contrat dev B) ---
# URL exacte + clé à récupérer auprès de l'équipe app.medicarepro.fr.
PROVISIONING_API_URL=
PROVISIONING_API_KEY=

# --- Chiffrement des secrets au repos (AES-256-GCM multi-clés) ---
# Format : v1:<base64 de 32 octets aléatoires>[,v2:...]
# Générer : node -e "console.log('v1:'+require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEYS=
ENCRYPTION_ACTIVE_KEY_ID=v1

# --- SEPA (mandats Core) — EN SOMMEIL ---
# Le prélèvement SEPA n'était qu'un palliatif faute de TPE récurrent.
# Depuis NB8179R, les renouvellements passent par la carte : l'étape
# mandat du tunnel reste coupée (CHECKOUT_SEPA_ENABLED absent = false)
# et ces variables ne servent que si on la réactive un jour.
SEPA_ICS=
# Pré-notification : 14 jours calendaires MINIMUM (obligation légale).
SEPA_PRENOTIFY_DAYS=14

# --- Alertes internes billing (incidents, remises, synchro app) ---
BILLING_ALERTS_TO=contact@medicarepro.fr

# --- Cloudflare Turnstile (anti-bot du checkout) ---
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Infra ---
# Proxys de confiance devant l'app (Traefik/Coolify = 1) pour lire l'IP client.
TRUSTED_PROXY_HOPS=1
# Plans vendables : 'monthly' | 'annual' | 'all'.
# La fréquence de reconduction est portée par le CODE SITE Monetico (champ
# `societe`), pas par la commande : un code site = une fréquence. On ne vend
# donc QUE les formules dont un code site porte le rythme.
#   code site medicarepr = « Tous les mois »  → CHECKOUT_PLANS=monthly
# 'all' suppose un second code site « Page de paiement » en fréquence
# annuelle, et le champ societe choisi selon le plan.
CHECKOUT_PLANS=monthly
