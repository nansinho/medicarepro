# ============================================================
# MediCare Pro — vitrine + CMS
# Copier vers .env.local puis remplir. Tout ce qui est Supabase/
# IA/GSC/SMTP est OPTIONNEL en Phase 1 : sans ces variables, le
# site sert le contenu embarqué (fallback) et l'admin est inactif.
# ============================================================

# URL publique du site vitrine
NEXT_PUBLIC_SITE_URL=https://medicarepro.fr

# URL du logiciel MediCare (app SaaS) vers lequel la vitrine redirige (inscription, connexion).
NEXT_PUBLIC_APP_URL=https://app.medicarepro.fr

# --- Supabase (CMS) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Réservé aux scripts (migrations/seed) — jamais lu par l'app :
SUPABASE_DB_URL=

# --- Secrets applicatifs ---
# Protège les routes /api/jobs/* (cron) — 32+ caractères aléatoires
CRON_SECRET=
# Protège l'activation de la preview brouillon (/api/draft)
DRAFT_PREVIEW_SECRET=

# --- IA (génération articles & pages villes) ---
ANTHROPIC_API_KEY=
# ID de modèle versionné (vérifier la liste via GET /v1/models)
ANTHROPIC_MODEL=

# --- Google Search Console (suivi du référencement) ---
GSC_SITE_URL=sc-domain:medicarepro.fr
# Clé JSON du service account, encodée en base64
GSC_SERVICE_ACCOUNT_KEY_B64=

# --- Email transactionnel (notifications contact, opt-in newsletter) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=contact@medicarepro.fr
